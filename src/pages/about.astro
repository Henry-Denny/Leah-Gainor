---
import MainLayout from '../layouts/MainLayout.astro';
import { Content as AboutPage } from '../content/about.md';
import siteConfig from '../../site.config.mjs';

const profileImage = siteConfig.profileImage;
const base = import.meta.env.BASE_URL;

export function getAge() {
	const today = new Date();
	const dob = new Date('2004-07-24');

	let age = today.getFullYear() - dob.getFullYear();
	const m = today.getMonth() - dob.getMonth();
	const d = today.getDate() - dob.getDate();

	if (m < 0 || (m == 0 && d < 0)) {
		age--;
	}
	return age;
}
---

<MainLayout>
	<section class="pt-32 pb-20">
		<div class="container-custom">
			<div class="max-w-2xl mx-auto text-center mb-16">
				<h1 class="text-4xl md:text-5xl font-bold mb-4">About Me</h1>
			</div>

			<div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
				<div>
					<img
						src=`${base}images/${profileImage}`
						alt="Profile image"
						class="w-full h-auto rounded-lg shadow-lg border-8 my-4 border-white md:p-4"
						width="720"
						height="720"
					/>
				</div>

				<div class="prose text-gray-700 mb-6">
					<h3>My Background</h3>
					<p>
						Leah Gainor is a {getAge()}-year-old British photographer based in the South West of
						England. Her practice is driven by curiosity and a personal connection to the subjects
						she explores. Leah’s work often begins with something that captures her interest,
						whether through experience, memory, or a desire to understand it more deeply and grows
						into a thoughtful visual investigation through photography.
					</p>
				</div>
			</div>
		</div>
	</section>
</MainLayout>
